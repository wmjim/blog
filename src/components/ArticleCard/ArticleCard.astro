---
import { getDescription, fmtTime } from "@/utils/index";
const { post } = Astro.props;
const description = getDescription(post);
import getCover from "@/utils/getCover";
const ARTICLE_COVER: string = await getCover(post.data.cover);
import "./ArticleCard.less";
---

<article class={`vh-article-item vh-animation vh-animation-init${post.data.top ? " active" : ""}`}>
	<a class="vh-article-thumb" href={`/article/${post.data.id}`}>
		<img src="/assets/images/lazy-loading.webp" data-vh-lz-src={ARTICLE_COVER} alt={post.data.title} />
	</a>
	<div class="vh-article-body">
		<header>
			<a class="vh-article-cat" href={`/categories/${post.data.categories}`}>{post.data.categories}</a>
			<h2 class="title"><a href={`/article/${post.data.id}`}>{post.data.title}</a></h2>
			<time datetime={fmtTime(post.data.date)}>{fmtTime(post.data.date, "MM-DD")}</time>
		</header>
		<p class="vh-article-excerpt vh-ellipsis line-2">{description}</p>
		<div class="vh-article-taglist">
			{post.data.tags.map((tag: string) => <a href={`/tag/${tag}`}>#{tag}</a>)}
		</div>
	</div>
</article>
